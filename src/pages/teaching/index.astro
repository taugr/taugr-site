const icons = {
  file: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z" /><path d="M14 2v6h6" /><path d="M8 13h8" /><path d="M8 17h6" />',
  globe: '<circle cx="12" cy="12" r="10" /><path d="M2 12h20" /><path d="M12 2a15.3 15.3 0 0 1 0 20" /><path d="M12 2a15.3 15.3 0 0 0 0 20" />',
  image: '<rect x="3" y="5" width="18" height="14" rx="2" /><circle cx="8.5" cy="10.5" r="1.5" /><path d="m21 15-5-5L5 21" />',
  linkedin: '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6Z" /><rect x="2" y="9" width="4" height="12" /><circle cx="4" cy="4" r="2" />',
  video: '<path d="m22 8-6 4 6 4V8Z" /><rect x="2" y="6" width="14" height="12" rx="2" />',
};
---

<BaseLayout title="Teaching — taugr" description="Learning labs, workshops, and masterclasses by taugr.">
  <h1 class="text-[1.6rem] font-bold text-(--color-text) tracking-tight mb-1">Teaching</h1>
  <p class="text-[0.95rem] text-(--color-text-secondary) mb-8">
    Learning labs, workshops, and masterclasses.
  </p>

  <section>
    <div class="space-y-4">
      {items.map(item => (
        <article class="border border-(--color-border-light) rounded-lg p-4 transition-all hover:border-(--color-border) hover:bg-(--color-project-hover) hover:-translate-y-px flex flex-col gap-4 sm:flex-row sm:items-start">
          <div class="min-w-0 flex-1">
              <h3 class="text-[1rem] text-(--color-link) font-semibold leading-tight">
              <a href={item.links[0].href} class="inline-flex items-center gap-1.5 hover:underline" target={item.links[0].href.startsWith('/') ? undefined : '_blank'} rel={item.links[0].href.startsWith('/') ? undefined : 'noopener'}>
                <span>{item.title}</span>
                <svg aria-hidden="true" viewBox="0 0 24 24" class="h-3 w-3 fill-none stroke-current stroke-2">
                  <path d="M7 17 17 7" />
                  <path d="M9 7h8v8" />
                </svg>
              </a>
            </h3>
            <p class="mt-0.5 text-[0.86rem] text-(--color-text)">{[item.host, item.format].filter(Boolean).join(' · ')}</p>
            <p class="mt-1 text-[0.82rem] text-(--color-text-tertiary)">{item.date} · {item.location}</p>
            <p class="mt-2 text-[0.9rem] text-(--color-text-secondary) leading-relaxed">{item.description}</p>
            <div class="flex flex-wrap items-center gap-3 mt-3 text-[0.82rem]">
              {item.links.map((link, index) => (
                <>
                  {index > 0 && <span class="h-3.5 w-px bg-(--color-border-light)" aria-hidden="true"></span>}
                  <a href={link.href} class="inline-flex items-center gap-1.5 text-(--color-link) font-medium hover:underline" target={link.href.startsWith('/') ? undefined : '_blank'} rel={link.href.startsWith('/') ? undefined : 'noopener'}>
                    <svg aria-hidden="true" viewBox="0 0 24 24" class="h-3.5 w-3.5 fill-none stroke-current stroke-2" set:html={icons[link.icon]} />
                    <span>{link.label}</span>
                  </a>
                </>
              ))}
            </div>
          </div>
          <button
            type="button"
            class="group relative flex h-28 w-full shrink-0 cursor-zoom-in items-center justify-center overflow-hidden rounded-md border border-(--color-border-light) bg-(--color-bg-secondary) p-1.5 shadow-[inset_0_1px_0_rgba(255,255,255,0.18)] transition hover:border-(--color-border) focus:outline-none focus-visible:ring-2 focus-visible:ring-(--color-link) sm:w-36"
            data-teaching-lightbox-media={JSON.stringify(item.media)}
            data-teaching-lightbox-index="0"
            aria-label={`Open larger image for ${item.title}`}
          >
            <img src={item.media[0].src} alt={item.media[0].alt} class="max-h-full max-w-full object-contain" loading="lazy" />
            {item.media.length > 1 && (
              <span class="absolute left-1.5 top-1.5 rounded bg-(--color-bg)/90 px-1.5 py-0.5 text-[0.7rem] font-semibold text-(--color-text-secondary) shadow-sm" aria-hidden="true">
                +{item.media.length - 1}
              </span>
            )}
            <span class="absolute bottom-1.5 right-1.5 rounded bg-(--color-bg)/90 px-1.5 py-1 text-(--color-link) opacity-0 shadow-sm transition group-hover:opacity-100 group-focus-visible:opacity-100" aria-hidden="true">
              <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 fill-none stroke-current stroke-2">
                <path d="M15 3h6v6" />
                <path d="M10 14 21 3" />
                <path d="M9 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-4" />
              </svg>
            </span>
          </button>
        </article>
      ))}
    </div>
  </section>

  <dialog id="teaching-lightbox" class="m-auto max-h-[92vh] max-w-[92vw] rounded-lg border border-(--color-border-light) bg-(--color-bg) p-0 shadow-2xl backdrop:bg-black/70">
    <div class="relative p-3">
      <button
        type="button"
        class="absolute right-5 top-5 z-10 flex h-8 w-8 items-center justify-center rounded-full border border-(--color-border-light) bg-(--color-bg)/90 text-[0.8rem] font-semibold text-(--color-text-secondary) shadow-sm transition hover:text-(--color-text) focus:outline-none focus-visible:ring-2 focus-visible:ring-(--color-link)"
        data-teaching-lightbox-close
        aria-label="Close image"
      >
        x
      </button>
      <button
        type="button"
        class="absolute left-5 top-1/2 z-10 hidden h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full border border-(--color-border-light) bg-(--color-bg)/90 text-(--color-text-secondary) shadow-sm transition hover:text-(--color-text) focus:outline-none focus-visible:ring-2 focus-visible:ring-(--color-link)"
        data-teaching-lightbox-prev
        aria-label="Previous image"
      >
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current stroke-2">
          <path d="m15 18-6-6 6-6" />
        </svg>
      </button>
      <button
        type="button"
        class="absolute right-5 top-1/2 z-10 hidden h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full border border-(--color-border-light) bg-(--color-bg)/90 text-(--color-text-secondary) shadow-sm transition hover:text-(--color-text) focus:outline-none focus-visible:ring-2 focus-visible:ring-(--color-link)"
        data-teaching-lightbox-next
        aria-label="Next image"
      >
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current stroke-2">
          <path d="m9 18 6-6-6-6" />
        </svg>
      </button>
      <img data-teaching-lightbox-image alt="" class="max-h-[84vh] max-w-[88vw] rounded-md object-contain" />
      <p class="mt-2 text-center text-[0.82rem] text-(--color-text-secondary)" data-teaching-lightbox-caption></p>
    </div>
  </dialog>

  <script is:inline>
    const lightbox = document.getElementById('teaching-lightbox');
    const lightboxImage = lightbox?.querySelector('[data-teaching-lightbox-image]');
    const closeButton = lightbox?.querySelector('[data-teaching-lightbox-close]');
    const prevButton = lightbox?.querySelector('[data-teaching-lightbox-prev]');
    const nextButton = lightbox?.querySelector('[data-teaching-lightbox-next]');
    const lightboxCaption = lightbox?.querySelector('[data-teaching-lightbox-caption]');
    let lightboxMedia = [];
    let lightboxIndex = 0;

    const updateLightboxImage = () => {
      if (!(lightboxImage instanceof HTMLImageElement)) {
        return;
      }

      const item = lightboxMedia[lightboxIndex];
      if (!item) {
        return;
      }

      lightboxImage.src = item.src;
      lightboxImage.alt = item.alt || '';

      if (lightboxCaption) {
        const count = lightboxMedia.length > 1 ? `${lightboxIndex + 1} of ${lightboxMedia.length}` : '';
        lightboxCaption.textContent = [item.label, count].filter(Boolean).join(' · ');
      }

      const hasGallery = lightboxMedia.length > 1;
      prevButton?.classList.toggle('hidden', !hasGallery);
      prevButton?.classList.toggle('flex', hasGallery);
      nextButton?.classList.toggle('hidden', !hasGallery);
      nextButton?.classList.toggle('flex', hasGallery);
    };

    document.querySelectorAll('[data-teaching-lightbox-media]').forEach((button) => {
      button.addEventListener('click', () => {
        if (!(lightbox instanceof HTMLDialogElement) || !(lightboxImage instanceof HTMLImageElement)) {
          return;
        }

        try {
          lightboxMedia = JSON.parse(button.dataset.teachingLightboxMedia || '[]');
        } catch {
          lightboxMedia = [];
        }

        lightboxIndex = Number(button.dataset.teachingLightboxIndex || 0);
        updateLightboxImage();
        lightbox.showModal();
      });
    });

    closeButton?.addEventListener('click', () => {
      if (lightbox instanceof HTMLDialogElement) {
        lightbox.close();
      }
    });

    prevButton?.addEventListener('click', () => {
      lightboxIndex = (lightboxIndex - 1 + lightboxMedia.length) % lightboxMedia.length;
      updateLightboxImage();
    });

    nextButton?.addEventListener('click', () => {
      lightboxIndex = (lightboxIndex + 1) % lightboxMedia.length;
      updateLightboxImage();
    });

    lightbox?.addEventListener('click', (event) => {
      if (event.target === lightbox && lightbox instanceof HTMLDialogElement) {
        lightbox.close();
      }
    });

    lightbox?.addEventListener('close', () => {
      if (lightboxImage instanceof HTMLImageElement) {
        lightboxImage.removeAttribute('src');
        lightboxImage.alt = '';
      }
      if (lightboxCaption) {
        lightboxCaption.textContent = '';
      }
    });
  </script>
</BaseLayout>
