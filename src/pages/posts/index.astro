---
import { SITE } from '../../site';

const destination = '/archive/';
const redirectURL = new URL(destination, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="refresh" content={`0; url=${destination}`} />
    <link rel="canonical" href={redirectURL} />
    <title>Posts — {SITE.name}</title>
    <script is:inline define:vars={{ destination }}>
      location.replace(destination);
    </script>
  </head>
  <body>
    <p>Posts have moved to <a href={destination}>{redirectURL.href}</a>.</p>
  </body>
</html>
