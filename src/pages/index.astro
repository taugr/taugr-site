---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { SITE } from '../site';

const projects = await getCollection('projects');
const featuredProjects = projects
  .filter(project => project.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const recentEngagements = [
  {
    title: 'From Idea to Prototype',
    kind: 'Workshop',
    event: 'AI Onramp by TUMO Labs',
    date: 'Jun 8–19, 2026',
    location: 'TUMO Labs, Yerevan, Armenia',
    href: '/teaching/',
    image: '/img/teaching/from-idea-to-prototype.webp',
    imageAlt: 'From Idea to Prototype with AI workshop flyer',
  },
  {
    title: 'Your New AI Co-Worker',
    kind: 'Session',
    event: 'AI Onramp by TUMO Labs',
    date: 'Apr 17, 2026',
    location: 'TUMO Labs, Yerevan, Armenia',
    href: '/speaking/',
    image: '/img/speaking/your-new-ai-coworker.webp',
    imageAlt: 'Your New AI Co-Worker session',
  },
];
---

<BaseLayout
  title={`${SITE.name} — coding, research, teaching, and projects`}
  description={SITE.description}
  wide
>
  <section class="home-hero" aria-labelledby="home-title">
    <div class="home-hero__copy">
      <h1 id="home-title">I build, research,<br />and teach with AI.</h1>
      <p>
        I’m Lead AI Engineer at the TUMO Center for Creative Technologies, a free educational
        program where teens build skills in technology and design.
      </p>
      <div class="home-hero__actions">
        <a href="#selected-projects" class="button button--primary">
          <span>Explore my work</span><i class="ph ph-arrow-right" aria-hidden="true"></i>
        </a>
        <a href="/about/" class="button button--text">
          <span>About Tom</span><i class="ph ph-arrow-right" aria-hidden="true"></i>
        </a>
      </div>
    </div>

    <aside class="home-profile" aria-label="About Tom Auger">
      <img src="/img/profile.webp" alt="Tom Auger" loading="eager" decoding="async" />
      <div class="home-profile__text">
        <p class="home-profile__eyebrow">Tom Auger</p>
        <p>Coding, researching, and teaching with AI.</p>
        <p>Engineer, researcher, educator, speaker, and open-source builder.</p>
      </div>
    </aside>
  </section>

  <section id="selected-projects" class="home-section" aria-labelledby="projects-title">
    <div class="section-heading">
      <h2 id="projects-title">Selected projects</h2>
      <span aria-hidden="true"></span>
      <a href="/projects/">View all</a>
    </div>
    <div class="project-list project-list--featured">
      {featuredProjects.map(project => (
        <ProjectCard
          name={project.data.name}
          description={project.data.description}
          date={project.data.date}
          type={project.data.type}
          tech={project.data.tech}
          github={project.data.github}
          url={project.data.url}
          image={project.data.image}
          imageAlt={project.data.imageAlt}
          variant="featured"
        />
      ))}
    </div>
  </section>

  <section class="home-section home-section--engagements" aria-labelledby="engagements-title">
    <div class="section-heading">
      <h2 id="engagements-title">Recent teaching &amp; speaking</h2>
      <span aria-hidden="true"></span>
      <div class="section-heading__links">
        <a href="/teaching/">Teaching</a>
        <a href="/speaking/">Speaking</a>
      </div>
    </div>
    <div class="engagement-grid">
      {recentEngagements.map(item => (
        <article class="engagement">
          <a href={item.href} class="engagement__image" tabindex="-1" aria-hidden="true">
            <img src={item.image} alt="" loading="lazy" decoding="async" />
          </a>
          <div class="engagement__content">
            <h3>
              <a
                href={item.href}
                data-engagement-title={item.title}
                data-engagement-kind={item.kind}
              >
                {item.title}
              </a>
            </h3>
            <p class="engagement__type">{item.kind} <span>·</span> {item.event}</p>
            <div class="engagement__meta">
              <span><i class="ph ph-calendar-blank" aria-hidden="true"></i>{item.date}</span>
              <span><i class="ph ph-map-pin" aria-hidden="true"></i>{item.location}</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll('[data-engagement-title]').forEach(function (el) {
      el.addEventListener('click', function () {
        window.posthog?.capture('homepage_engagement_clicked', {
          engagement_title: el.getAttribute('data-engagement-title'),
          engagement_kind: el.getAttribute('data-engagement-kind'),
          link_href: el.getAttribute('href'),
        });
      });
    });
  </script>
</BaseLayout>
