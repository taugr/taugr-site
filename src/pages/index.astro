---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { SITE } from '../site';

const projects = await getCollection('projects');
const featuredProjects = projects
  .filter(project => project.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const recentEngagements = [
  {
    title: 'Your New AI Co-Worker',
    kind: 'Session',
    event: 'AI Onramp by TUMO Labs',
    date: 'Apr 17, 2026, 19:00',
    location: 'TUMO Labs, Yerevan, Armenia',
    description:
      'A practical session on applying AI to everyday work processes, choosing what to automate first, turning AI into an autonomous working unit, and structuring prompts.',
    href: '/speaking/',
    image: '/img/speaking/your-new-ai-coworker.jpeg',
    imageAlt: 'Your New AI Co-Worker session photo',
  },
  {
    title: 'TUMO Gunma AI Learning Lab',
    kind: 'Workshop',
    event: 'TUMO Gunma / Gunma Prefecture',
    date: 'Nov 1-3, 2025',
    location: 'Takasaki, Japan',
    description:
      'A three-day AI learning lab where students used generative AI tools to create short Disney-quality movies, ending with a final premiere.',
    href: '/teaching/',
    image: '/img/teaching/gunma-ai-lab-photo-2.jpg',
    imageAlt: 'TUMO Gunma AI learning lab session photo',
  },
  {
    title: 'Engineering AI for Education',
    kind: 'Talk',
    event: 'DataFest Yerevan 2025',
    date: 'Sep 12-13, 2025',
    location: 'Woods Center, Yerevan, Armenia',
    description:
      "A talk on how TUMO is engineering AI-driven applications that guide self-learning, adapt to each student's pace and interests, and support personalized learning paths.",
    href: '/speaking/',
    image: '/img/speaking/datafest-yerevan-2025-flyer.jpeg',
    imageAlt: 'DataFest Yerevan 2025 Engineering AI for Education flyer',
  },
];
---

<BaseLayout title={`${SITE.name} — coding, research, teaching, and projects`} description={SITE.description}>
  <section class="mb-12 flex flex-col items-start gap-5 sm:flex-row sm:items-center">
    <img
      src="/img/profile.png"
      alt="Tom Auger"
      class="h-24 w-24 shrink-0 rounded-full border border-(--color-border-light) object-cover sm:h-28 sm:w-28"
      loading="eager"
      decoding="async"
    />
    <div>
      <p class="text-[0.78rem] font-semibold uppercase tracking-wide text-(--color-text-tertiary) mb-1">Tom Auger</p>
      <p class="text-[1rem] text-(--color-text-secondary) leading-relaxed mt-2">
        I like coding, researching, and teaching with AI 🤖.<br />
        I'm Lead AI Engineer at the TUMO Center for Creative Technologies, a free educational program where teens build skills in technology and design.
      </p>
    </div>
  </section>

  <section class="mb-12">
    <div class="flex items-baseline justify-between gap-4 mb-4">
      <h2 class="text-[1.05rem] font-semibold text-(--color-text)">Featured projects</h2>
      <a href="/projects/" class="text-[0.82rem] text-(--color-link) font-medium no-underline hover:underline">all projects</a>
    </div>
    {featuredProjects.map(project => (
      <ProjectCard
        name={project.data.name}
        description={project.data.description}
        date={project.data.date}
        type={project.data.type}
        tech={project.data.tech}
        github={project.data.github}
        url={project.data.url}
        image={project.data.image}
        imageAlt={project.data.imageAlt}
      />
    ))}
  </section>

  <section class="mb-12">
    <div class="flex items-baseline justify-between gap-4 mb-4">
      <h2 class="text-[1.05rem] font-semibold text-(--color-text)">Recent engagements</h2>
      <div class="flex gap-3">
        <a href="/speaking/" class="text-[0.82rem] text-(--color-link) font-medium no-underline hover:underline">speaking</a>
        <a href="/teaching/" class="text-[0.82rem] text-(--color-link) font-medium no-underline hover:underline">teaching</a>
      </div>
    </div>
    <div class="space-y-4">
      {recentEngagements.map(item => (
        <article class="flex flex-col gap-4 rounded-[6px] border border-(--color-border-light) bg-(--color-surface) p-4 sm:flex-row sm:items-start sm:gap-5">
          <div class="min-w-0 flex-1">
            <p class="text-[0.75rem] font-semibold uppercase tracking-wide text-(--color-text-tertiary)">{item.kind}</p>
            <h3 class="mt-1 text-[0.98rem] font-semibold leading-tight text-(--color-link)">
              <a href={item.href} class="inline-flex items-center gap-1.5 no-underline hover:underline">
                <span>{item.title}</span>
                <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    d="M7 17 17 7M9 7h8v8"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </a>
            </h3>
            <p class="mt-0.5 text-[0.86rem] text-(--color-text)">{item.event}</p>
            <p class="mt-1 text-[0.82rem] text-(--color-text-tertiary)">{item.date} · {item.location}</p>
            <p class="mt-2 text-[0.9rem] leading-relaxed text-(--color-text-secondary)">{item.description}</p>
          </div>
          <div class="flex h-28 w-full shrink-0 items-center justify-center rounded-[6px] border border-(--color-border-light) bg-(--color-surface-muted) p-1.5 sm:h-28 sm:w-40">
            <img
              src={item.image}
              alt={item.imageAlt}
              class="h-full w-full rounded-[4px] object-contain"
              loading="lazy"
              decoding="async"
            />
          </div>
        </article>
      ))}
    </div>
  </section>

</BaseLayout>
