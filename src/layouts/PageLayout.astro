---
import BaseLayout from './BaseLayout.astro';
import { SITE } from '../site';

const { frontmatter } = Astro.props;
---

<BaseLayout title={`${frontmatter.title} — ${SITE.name}`} description={frontmatter.description}>
  <article>
    <h1 class="text-[1.6rem] font-bold leading-tight tracking-tight text-(--color-text)">
      {frontmatter.title}
    </h1>
    <div class="mt-6 prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style is:global>
  .prose p {
    font-size: 1rem;
    color: var(--color-text);
    margin-bottom: 1.3rem;
    line-height: 1.85;
  }
  .prose strong { font-weight: 600; }
  .prose a {
    color: var(--color-link);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose a:hover { text-decoration-thickness: 2px; }
  .prose h1 {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--color-text);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .prose h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .prose h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .prose ul, .prose ol {
    padding-left: 1.5rem;
    margin-bottom: 1.3rem;
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.85;
  }
  .prose li { margin-bottom: 0.3rem; }
  .prose blockquote {
    border-left: 3px solid var(--color-border);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--color-text-secondary);
    font-style: italic;
  }
  .prose img {
    border-radius: 0.375rem;
    margin: 1.5rem 0;
  }
  .prose code:not(pre code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-code-bg);
    border: 1px solid var(--color-code-border);
    padding: 0.1em 0.3em;
    border-radius: 3px;
  }
</style>
