---
import ThemeToggle from '../components/ThemeToggle.astro';
import PostHog from '../components/posthog.astro';
import { NAV_ITEMS, PROFILE_LINKS, SITE } from '../site';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  publishedTime?: Date | string;
  tags?: string[];
  wide?: boolean;
}

const {
  title,
  description = SITE.description,
  ogImage = '/social-card.png',
  ogType = 'website',
  publishedTime,
  tags = [],
  wide = false,
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(ogImage, Astro.site);
const publishedDate = publishedTime ? new Date(publishedTime).toISOString() : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={SITE.name} href={SITE.links.rss} />
    <link rel="alternate" type="text/plain" title="LLMs.txt" href="/llms.txt" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <meta name="description" content={description} />
    <meta name="author" content={SITE.footerName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={SITE.description} />
    {ogType === 'article' && <meta property="article:author" content={SITE.footerName} />}
    {publishedDate && <meta property="article:published_time" content={publishedDate} />}
    {tags.map(tag => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@tomaugr" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL} />
    <meta name="twitter:image:alt" content={SITE.description} />
    <title>{title}</title>
    <script is:inline>
      // Prevent flash of wrong theme
      (function() {
        const theme = localStorage.getItem('theme') || 'dark';
        if (theme === 'dark') document.documentElement.classList.add('dark');
      })();
    </script>
    <PostHog />
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="site-header__inner">
          <a href="/" class="site-brand">
            {SITE.name}
          </a>
          <nav class="site-nav" aria-label="Primary navigation">
          {NAV_ITEMS.map(item => (
            <a
              href={item.href}
              class:list={[
                'site-nav__link',
                item.href === '/' && 'site-nav__home',
                Astro.url.pathname === item.href || (item.href !== '/' && Astro.url.pathname.startsWith(item.href))
                  ? 'site-nav__link--active'
                  : '',
              ]}
            >
              {item.label}
            </a>
          ))}
          </nav>
          <div class="site-actions">
            {PROFILE_LINKS.map(link => (
              <a
                href={link.href}
                class="site-actions__link"
                target="_blank"
                rel="me noopener"
                aria-label={link.label}
                data-profile-link={link.label}
              >
                <i
                  class:list={[
                    'ph',
                    link.label === 'github' && 'ph-github-logo',
                    link.label === 'linkedin' && 'ph-linkedin-logo',
                    link.label === 'x' && 'ph-x-logo',
                  ]}
                  aria-hidden="true"
                ></i>
              </a>
            ))}
            <ThemeToggle />
          </div>
        </div>
      </header>

      <main class:list={['site-main', wide ? 'site-main--wide' : 'site-main--reading']}>
        <slot />
      </main>

      <footer class="site-footer">
        <span>&copy; {new Date().getFullYear()} {SITE.footerName}</span>
        <span class="site-footer__links">
          {PROFILE_LINKS.map(link => (
            <>
              <a href={link.href} target="_blank" rel="me noopener" data-profile-link={link.label}>{link.label}</a>
            </>
          ))}
          <a href={SITE.links.archive}>archive</a>
          <a href={SITE.links.rss} id="rss-link">rss</a>
        </span>
      </footer>
    </div>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('[data-profile-link]').forEach(function (el) {
          el.addEventListener('click', function () {
            window.posthog?.capture('profile_link_clicked', {
              link_label: el.getAttribute('data-profile-link'),
              link_href: el.getAttribute('href'),
            });
          });
        });

        var rssLink = document.getElementById('rss-link');
        rssLink?.addEventListener('click', function () {
          window.posthog?.capture('rss_feed_clicked');
        });
      });
    </script>
  </body>
</html>
