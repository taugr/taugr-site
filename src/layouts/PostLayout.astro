---
import BaseLayout from './BaseLayout.astro';
import { SITE } from '../site';

const { frontmatter } = Astro.props;

function formatDate(date: Date | string): string {
  const d = typeof date === 'string' ? new Date(date) : date;
  return d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}

const tagColors = [
  { bg: 'var(--color-tag-purple-bg)', text: 'var(--color-tag-purple-text)', border: 'var(--color-tag-purple-border)' },
  { bg: 'var(--color-tag-blue-bg)', text: 'var(--color-tag-blue-text)', border: 'var(--color-tag-blue-border)' },
  { bg: 'var(--color-tag-green-bg)', text: 'var(--color-tag-green-text)', border: 'var(--color-tag-green-border)' },
  { bg: 'var(--color-tag-amber-bg)', text: 'var(--color-tag-amber-text)', border: 'var(--color-tag-amber-border)' },
  { bg: 'var(--color-tag-rose-bg)', text: 'var(--color-tag-rose-text)', border: 'var(--color-tag-rose-border)' },
];

function hashTag(tag: string): number {
  let hash = 0;
  for (let i = 0; i < tag.length; i++) {
    hash = ((hash << 5) - hash) + tag.charCodeAt(i);
    hash |= 0;
  }
  return Math.abs(hash) % tagColors.length;
}

function getTagColor(tag: string) {
  return tagColors[hashTag(tag)];
}
---

<BaseLayout title={`${frontmatter.title} — ${SITE.name}`} description={frontmatter.description}>
  <article>
    <div class="flex items-center gap-2 mb-2 text-[0.82rem] text-(--color-text-tertiary)">
      {formatDate(frontmatter.date)} · {frontmatter.readingTime || '5 min read'}
    </div>
    {frontmatter.tags?.length > 0 && (
      <div class="flex gap-1.5 mb-3">
        {frontmatter.tags.map((tag: string) => {
          const color = getTagColor(tag);
          return (
            <span
              class="text-[0.7rem] px-2 py-0.5 rounded border font-medium"
              style={`background: ${color.bg}; color: ${color.text}; border-color: ${color.border};`}
            >
              {tag}
            </span>
          );
        })}
      </div>
    )}
    <h1 class="text-[1.6rem] font-bold leading-tight tracking-tight text-(--color-text)">
      {frontmatter.title}
    </h1>
    <div class="mt-6 prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style is:global>
  .prose p {
    font-size: 1rem;
    color: var(--color-text);
    margin-bottom: 1.3rem;
    line-height: 1.85;
  }
  .prose strong { font-weight: 600; }
  .prose a {
    color: var(--color-link);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose a:hover { text-decoration-thickness: 2px; }
  .prose h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .prose h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .prose ul, .prose ol {
    padding-left: 1.5rem;
    margin-bottom: 1.3rem;
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.85;
  }
  .prose li { margin-bottom: 0.3rem; }
  .prose blockquote {
    border-left: 3px solid var(--color-border);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--color-text-secondary);
    font-style: italic;
  }
  .prose img {
    border-radius: 0.375rem;
    margin: 1.5rem 0;
  }
  .prose code:not(pre code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-code-bg);
    border: 1px solid var(--color-code-border);
    padding: 0.1em 0.3em;
    border-radius: 3px;
  }
</style>
