---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  name: string;
  description: string;
  date?: Date;
  type?: 'personal' | 'open-source' | 'commercial';
  tech: string[];
  github?: string;
  url?: string;
  image?: ImageMetadata;
  imageAlt?: string;
  variant?: 'card' | 'featured';
}

const {
  name,
  description,
  date,
  tech,
  github,
  url,
  image,
  imageAlt,
  variant = 'card',
} = Astro.props;
const formattedDate = date?.toLocaleDateString('en', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
  timeZone: 'UTC',
});
const primaryUrl = url ?? github;
const primaryTech = tech.filter(tag => tag.toLowerCase() !== 'prototype').slice(0, 3);
---

<article class:list={['project', variant === 'featured' ? 'project--featured' : 'project--card']}>
  {image && (
    <div class="project__art">
      <Image
        src={image}
        alt={imageAlt || name}
        width={image.width}
        height={image.height}
        class="project__image"
        loading="lazy"
      />
    </div>
  )}

  <div class="project__content">
    <h3 class="project__title">
      {primaryUrl ? (
        <a
          href={primaryUrl}
          target="_blank"
          rel="noopener"
          data-project-link-name={name}
          data-project-link-type="primary"
        >
          <span>{name}</span>
          <i class="ph ph-arrow-up-right" aria-hidden="true"></i>
        </a>
      ) : (
        name
      )}
    </h3>
    <p class="project__description">{description}</p>
  </div>

  <div class="project__meta">
    {formattedDate && (
      <p><i class="ph ph-calendar-blank" aria-hidden="true"></i><span>{formattedDate}</span></p>
    )}
    {primaryTech.length > 0 && (
      <p><i class="ph ph-code" aria-hidden="true"></i><span>{primaryTech.join(', ')}</span></p>
    )}
    {tech.length > 0 && variant === 'featured' && (
      <p class="project__tags"><i class="ph ph-tag" aria-hidden="true"></i><span>{tech.join(', ')}</span></p>
    )}
  </div>

  <div class="project__links">
    {github && (
      <a
        href={github}
        target="_blank"
        rel="noopener"
        data-project-link-name={name}
        data-project-link-type="github"
      >
        <i class="ph ph-github-logo" aria-hidden="true"></i><span>github</span>
      </a>
    )}
    {url && (
      <a
        href={url}
        target="_blank"
        rel="noopener"
        data-project-link-name={name}
        data-project-link-type="site"
      >
        <i class="ph ph-globe" aria-hidden="true"></i><span>site</span>
      </a>
    )}
  </div>
</article>

<script is:inline>
  document.querySelectorAll('[data-project-link-name]').forEach(function (el) {
    el.addEventListener('click', function () {
      window.posthog?.capture('project_link_clicked', {
        project_name: el.getAttribute('data-project-link-name'),
        link_type: el.getAttribute('data-project-link-type'),
        link_href: el.getAttribute('href'),
      });
    });
  });
</script>
